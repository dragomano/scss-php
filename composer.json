{
  "name": "bugo/scss-php",
  "description": "Pure PHP compiler for SCSS/Sass, fully compatible with the Dart Sass specification",
  "keywords": [
    "scss",
    "sass",
    "css",
    "compiler",
    "dart-sass",
    "pure-php",
    "native"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Bugo",
      "email": "bugo@dragomano.ru"
    }
  ],
  "autoload": {
    "psr-4": {
      "Bugo\\SCSS\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2",
    "ext-ctype": "*",
    "bugo/iris": "^0.1",
    "psr/log": "^3.0",
    "psr/simple-cache": "^3.0",
    "symfony/filesystem": "^7.4|^8.0"
  },
  "require-dev": {
    "bugo/sass-embedded-php": "dev-main",
    "bugo/scss-benchmark-utils": "dev-main",
    "dg/bypass-finals": "^1.9",
    "friendsofphp/php-cs-fixer": "^3.94",
    "matthieumastadenis/couleur": "dev-fix-PHP-8.4-deprecation-warnings",
    "mockery/mockery": "dev-bugfix/spy-generics",
    "monolog/monolog": "^3.10",
    "pestphp/pest": "^3.8|^4.4",
    "phpstan/phpstan": "^2.1",
    "rector/rector": "^2.3",
    "scssphp/scssphp": "^2.1",
    "symfony/cache": "^7.4|^8.0",
    "symfony/var-dumper": "^7.4|^8.0",
    "vimeo/psalm": "^6.15"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/AlwinGarside/couleur"
    }
  ],
  "scripts": {
    "fix": "vendor/bin/php-cs-fixer fix",
    "rector": "vendor/bin/rector process --clear-cache",
    "check": "vendor/bin/rector process --dry-run --clear-cache",
    "phpstan": "vendor/bin/phpstan analyse -l 10 src --memory-limit=512M --debug --no-progress",
    "psalm": "vendor/bin/psalm --stats --no-cache",
    "benchmark": "php benchmark.php 6",
    "spaces": "php spaces.php",
    "test": "vendor/bin/pest --colors=always --display-warnings",
    "test-coverage": "vendor/bin/pest -d memory_limit=1G --colors=always --coverage --min=100",
    "test-coverage-clover": "vendor/bin/pest --colors=always --min=100 --coverage-clover coverage.xml",
    "test-coverage-html": "vendor/bin/pest --colors=always --min=100 --coverage-html coverage",
    "test-mutate": "vendor/bin/pest --colors=always --mutate --covered-only -d memory_limit=1G --path=src/Utils"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "bugo/sass-embedded-php": true,
      "pestphp/pest-plugin": true
    }
  }
}
